# =========================
# Java & Compiled Code
# =========================
*.class
*.log
*.ctxt
hs_err_pid*
replay_pid*

# =========================
# Packaging (Exclude jars)
# =========================
# We ignore .jar files so you don't accidentally commit your compiled plugin!
*.jar
*.war
*.zip
*.tar.gz
# (Optional) If you want to commit the gradle wrapper jar, uncomment the line below:
!gradle/wrapper/gradle-wrapper.jar

# =========================
# Gradle
# =========================
.gradle/
build/
out/
gradle-app.setting

# =========================
# IntelliJ IDEA
# =========================
.idea/
*.iml
*.iws
*.ipr

# =========================
# VS Code (Just in case you switch editors)
# =========================
.vscode/

# =========================
# OS Generated Files
# =========================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# =========================
# Local Server Testing
# =========================
# If you run a local Velocity proxy inside your project folder to test,
# you definitely want to ignore its generated files!
run/
server/
velocity.toml
forwarding.secret
plugins/